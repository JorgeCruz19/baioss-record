<Window x:Class="Baioss.Record.App.ChannelScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Programación" Height="440" Width="600"
        Background="#10131A" WindowStartupLocation="CenterOwner">
    <DockPanel>
        <!-- Cabecera -->
        <Border DockPanel.Dock="Top" Background="#0C0F15" Padding="16,12">
            <StackPanel>
                <TextBlock Text="{Binding HeaderText}" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="Grabaciones programadas de hoy en este canal." FontSize="11" Margin="0,2,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <!-- Sin grabaciones hoy -->
        <TextBlock DockPanel.Dock="Top" Text="No hay grabaciones programadas hoy en este canal."
                   Margin="16,16" FontSize="12" FontStyle="Italic" Foreground="{StaticResource TextSecondaryBrush}"
                   Visibility="{Binding NoRows, Converter={StaticResource BoolToVis}}"/>

        <!-- Tabla: Entrada · Salida · Título · Segmento -->
        <Border Margin="16,12" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1" CornerRadius="8"
                Visibility="{Binding HasRows, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="12,10,12,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72"/>
                        <ColumnDefinition Width="72"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="92"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="ENTRADA" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="SALIDA" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="2" Text="TÍTULO" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="3" Text="SEGMENTO" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                </Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                    <ItemsControl ItemsSource="{Binding Rows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{Binding RowBackground}" CornerRadius="6" Margin="6,2" Padding="6,7">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72"/>
                                            <ColumnDefinition Width="72"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="92"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding EntradaText}" FontFamily="Consolas" FontSize="12"
                                                   Foreground="{Binding RowForeground}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SalidaText}" FontFamily="Consolas" FontSize="12"
                                                   Foreground="{Binding RowForeground}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" Foreground="{Binding RowForeground}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding SegmentText}" FontSize="12"
                                                   Foreground="{Binding RowForeground}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </DockPanel>
</Window>
