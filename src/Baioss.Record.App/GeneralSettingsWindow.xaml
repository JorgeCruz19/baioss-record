<Window x:Class="Baioss.Record.App.GeneralSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración general" Width="680" SizeToContent="Height"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        Background="#10131A" WindowStartupLocation="CenterOwner">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#0C0F15" Padding="16,12">
            <StackPanel>
                <TextBlock Text="CONFIGURACIÓN GENERAL" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="Carpeta de destino y carta de ajuste por canal. El formato y la codificación se eligen en «⚙ Presets de grabación»."
                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#0C0F15" Padding="16,10">
            <Button Content="Cerrar" IsCancel="True" HorizontalAlignment="Right"
                    Height="32" MinWidth="100" Padding="20,0" Style="{StaticResource TransportButton}"/>
        </Border>

        <ItemsControl ItemsSource="{Binding Channels}" Margin="16,12">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,10">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{StaticResource AccentBrush}" CornerRadius="5" Width="28" Height="28" Margin="0,0,10,0">
                                        <TextBlock Text="{Binding Key}" FontSize="15" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Canal" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding ProfileText}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentBrush}" TextTrimming="CharacterEllipsis"/>
                            </Grid>

                            <TextBlock Text="CARPETA DE DESTINO" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding OutputDirectory}" IsReadOnly="True" Height="30"
                                         VerticalContentAlignment="Center" Padding="8,0" FontSize="12"/>
                                <Button Grid.Column="1" Content="Examinar…" Command="{Binding BrowseOutputCommand}"
                                        IsEnabled="{Binding CanConfigure}" Style="{StaticResource TransportButton}"
                                        Height="30" Padding="16,0" Margin="8,0,0,0"/>
                            </Grid>

                            <CheckBox Content="Carta de ajuste al perder señal (sigue grabando barras)" Margin="0,12,0,0"
                                      IsEnabled="{Binding CanConfigure}" IsChecked="{Binding SlateOnSignalLoss}"
                                      Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DockPanel>
</Window>
