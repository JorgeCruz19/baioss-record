<Window x:Class="Baioss.Record.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Baioss.Record.App"
        Title="Baioss Record" Height="900" Width="1600" WindowState="Maximized"
        Background="#10131A" WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- Barra de título de la app -->
        <Border DockPanel.Dock="Top" Background="#0C0F15" Padding="16,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="🛠 Configuración"
                            Command="{Binding OpenGeneralSettingsCommand}" Style="{StaticResource TransportButton}"/>
                    <Button Content="🎛 Entradas" Margin="8,0,0,0"
                            Command="{Binding OpenInputsCommand}" Style="{StaticResource TransportButton}"/>
                    <Button Content="🕒 Programación" Margin="8,0,0,0"
                            Command="{Binding OpenScheduleCommand}" Style="{StaticResource TransportButton}"/>
                    <Button Content="⚙ Presets de grabación" Margin="8,0,0,0"
                            Command="{Binding OpenPresetsCommand}" Style="{StaticResource TransportButton}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="BAIOSS" FontSize="18" FontWeight="Bold" Foreground="#E6E9EF"/>
                    <TextBlock Text="RECORD" FontSize="18" FontWeight="Bold" Foreground="#3B82F6" Margin="6,0,0,0"/>
                    <TextBlock Text="{Binding ChannelsSubtitle}" FontSize="13"
                               Foreground="#8A92A0" Margin="12,3,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Un panel por canal, SIEMPRE en una sola fila (UniformGrid Rows="1"): N canales → N columnas.
             Con más canales cada panel se hace más estrecho, pero el preview conserva toda la altura. -->
        <ItemsControl ItemsSource="{Binding Channels}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <local:ChannelView/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DockPanel>
</Window>
