<?xml version="1.0" encoding="utf-8"?>
<!--
  Perfil de release: aplicación de escritorio PORTABLE y self-contained (win-x64).
  No requiere instalar ningún runtime de .NET en el equipo destino: incluye el
  runtime de .NET 8, WPF y ASP.NET Core. El target BundleToolsOnPublish del .csproj
  copia ffmpeg/ffprobe y el clip demo en tools\ junto al .exe.

  Visual Studio: clic derecho en Baioss.Record.App > Publicar > este perfil.
  CLI equivalente: scripts\publish.ps1 (en la raíz del repo).
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishDir>..\..\publish\</PublishDir>
    <!-- Carpeta normal (no single-file): WPF + binarios nativos + tools\ se distribuyen mejor así. -->
    <PublishSingleFile>false</PublishSingleFile>
    <!-- Trimming DEBE quedar desactivado: WPF usa reflexión y se rompería. -->
    <PublishTrimmed>false</PublishTrimmed>
    <!-- Precompilación ReadyToRun: arranque más rápido (importante en un equipo de emisión). -->
    <PublishReadyToRun>true</PublishReadyToRun>
  </PropertyGroup>
</Project>
