<UserControl x:Class="Baioss.Record.App.ChannelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Baioss.Record.App">
    <Border Margin="10" Padding="14" CornerRadius="10"
            Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- cabecera -->
                <RowDefinition Height="*"/>     <!-- preview + medidores -->
                <RowDefinition Height="Auto"/>  <!-- tabla HOY (tareas programadas del día) -->
                <RowDefinition Height="Auto"/>  <!-- telemetría -->
                <RowDefinition Height="Auto"/>  <!-- transporte -->
            </Grid.RowDefinitions>

            <!-- Cabecera -->
            <Grid Grid.Row="0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource AccentBrush}" CornerRadius="6" Width="40" Height="40">
                        <TextBlock Text="{Binding Key}" FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Canal" FontSize="18" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0"
                                Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}">
                        <Ellipse Width="11" Height="11" Fill="{StaticResource RecBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="REC" Foreground="{StaticResource RecBrush}" FontWeight="Bold"
                                   Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border CornerRadius="4" Padding="10,5" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource SignalGrayBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SignalState}" Value="Locked">
                                        <Setter Property="Background" Value="{StaticResource SignalGreenBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SignalState}" Value="Unstable">
                                        <Setter Property="Background" Value="{StaticResource SignalAmberBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding SignalText}" FontSize="12" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Preview + medidores de audio. (La carpeta de destino y la carta de ajuste se configuran ahora
                 en «🛠 Configuración» de la barra superior; el formato/codificación en «⚙ Presets».) -->
            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Preview: textura D3D11 vía D3DImage (fallback WriteableBitmap), con overlays encima -->
                <Border Grid.Column="0" Background="{StaticResource PreviewBrush}" CornerRadius="6" ClipToBounds="True">
                    <Grid>
                        <Image x:Name="PreviewImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="LowQuality"/>

                        <!-- Franja de alarmas (negro/congelado/silencio/slate/disco): roja, sobre el preview -->
                        <Border VerticalAlignment="Top" Padding="10,6"
                                Visibility="{Binding HasAlarms, Converter={StaticResource BoolToVis}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource SignalAmberBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSlate}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource RecBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DiskCritical}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource RecBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="⚠" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="White"/>
                                <TextBlock Text="{Binding AlarmsText}" FontSize="12" FontWeight="Bold" Foreground="White"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Grid Margin="12">
                            <TextBlock Text="PGM" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Left" VerticalAlignment="Top"/>
                            <TextBlock Text="{Binding FormatText}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding Timecode}" FontFamily="Consolas" FontSize="30" FontWeight="Bold"
                                           HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding FrameCount, StringFormat=frame {0}}" FontFamily="Consolas"
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Medidores VU / Peak estéreo -->
                <Border Grid.Column="1" Width="96" Margin="12,0,0,0" Padding="10,8"
                        Background="#12161E" CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="AUDIO dBFS" FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>

                        <Grid Grid.Row="1" Margin="0,4,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding LeftPeakDb}" FontFamily="Consolas" FontSize="11"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding RightPeakDb}" FontFamily="Consolas" FontSize="11"
                                       HorizontalAlignment="Center"/>
                        </Grid>

                        <Grid Grid.Row="2" MinHeight="120">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <local:VuMeter Grid.Column="0" Level="{Binding LeftLevel}" Peak="{Binding LeftPeak}"
                                           HorizontalAlignment="Center"/>
                            <local:VuMeter Grid.Column="1" Level="{Binding RightLevel}" Peak="{Binding RightPeak}"
                                           HorizontalAlignment="Center"/>
                        </Grid>

                        <Grid Grid.Row="3" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="L" FontSize="11" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="R" FontSize="11" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Grid>

                        <Border Grid.Row="4" Margin="0,8,0,0" CornerRadius="3" Padding="0,3"
                                Background="{StaticResource RecBrush}"
                                Visibility="{Binding Clipping, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="CLIP" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Tabla HOY: tareas programadas del día para este canal; la grabación EN CURSO va resaltada.
                 Si hoy no hay nada pero sí una próxima, se muestra una pista en su lugar. -->
            <Border Grid.Row="2" Margin="0,10,0,0" Background="#12161E" CornerRadius="8"
                    BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1"
                    Visibility="{Binding ShowTodaySection, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="PROGRAMADAS HOY" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="12,8,12,2"/>
                    <!-- Hoy no hay: muestra la próxima grabación del canal. -->
                    <TextBlock Text="{Binding TodayEmptyText}" FontSize="11" Margin="12,2,12,8" TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Visibility="{Binding NoTodayTasks, Converter={StaticResource BoolToVis}}"/>
                    <Grid Margin="12,2,12,2" Visibility="{Binding HasTodayTasks, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="58"/>
                            <ColumnDefinition Width="58"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="78"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ENTRADA" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="SALIDA" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="2" Text="TÍTULO" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="3" Text="SEGMENTO" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Grid>
                    <ScrollViewer MaxHeight="140" VerticalScrollBarVisibility="Auto" Margin="0,0,0,6">
                        <ItemsControl ItemsSource="{Binding TodayTasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding RowBackground}" CornerRadius="4" Margin="6,1" Padding="6,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="58"/>
                                                <ColumnDefinition Width="58"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="78"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding EntradaText}" FontFamily="Consolas" FontSize="12"
                                                       Foreground="{Binding RowForeground}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SalidaText}" FontFamily="Consolas" FontSize="12"
                                                       Foreground="{Binding RowForeground}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" Foreground="{Binding RowForeground}"/>
                                            <TextBlock Grid.Column="3" Text="{Binding SegmentText}" FontSize="12"
                                                       Foreground="{Binding RowForeground}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Telemetría -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="2,12">
                <StackPanel Margin="0,0,26,0">
                    <TextBlock Text="FPS SALIDA" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding OutputFps, StringFormat={}{0:0.#}}" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Margin="0,0,26,0">
                    <TextBlock Text="BITRATE" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding BitrateText}" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Margin="0,0,26,0">
                    <TextBlock Text="DROPPED" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding DroppedFrames}" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Margin="0,0,26,0">
                    <TextBlock Text="ESTADO" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding RecordingState}" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel VerticalAlignment="Center"
                            Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="DISCO" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding DiskText}" FontSize="14" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DiskWarning}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource SignalAmberBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DiskCritical}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource RecBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <!-- Transporte -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,6,0,0">
                <Button Content="● Grabar"   Command="{Binding StartCommand}"  Style="{StaticResource StartButton}"/>
                <!-- «Detener» SOLO para grabaciones manuales; en las programadas se usa «Detener grabación automática». -->
                <Button Content="■ Detener"  Command="{Binding StopCommand}"   Style="{StaticResource StopButton}"
                        Visibility="{Binding ShowStopButton, Converter={StaticResource BoolToVis}}"/>
                <!-- Solo visible cuando hay una grabación PROGRAMADA en curso: la salta (esta ocurrencia)
                     sin afectar a las siguientes. -->
                <Button Content="⏏ Detener grabación automática" Command="{Binding SkipScheduledRecordingCommand}"
                        Style="{StaticResource TransportButton}" Background="{StaticResource SignalAmberBrush}"
                        Foreground="#10131A" FontWeight="Bold"
                        Visibility="{Binding IsScheduledRecording, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
