<Window x:Class="Baioss.Record.App.Presets.PresetManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Presets de grabación / encoding" Height="720" Width="1180"
        Background="#10131A" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="DarkList" TargetType="ListBox">
            <Setter Property="Background" Value="#12161E"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#0C0F15" Padding="12,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔍" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox Width="240" Height="26" VerticalContentAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                <Border Width="1" Background="{StaticResource PanelBorderBrush}" Margin="12,2"/>
                <Button Content="＋ Nuevo"   Command="{Binding NewCommand}"       Style="{StaticResource TransportButton}"/>
                <Button Content="✎ Editar"   Command="{Binding EditCommand}"      Style="{StaticResource TransportButton}"/>
                <Button Content="⧉ Duplicar" Command="{Binding DuplicateCommand}" Style="{StaticResource TransportButton}"/>
                <Button Content="🗑 Eliminar" Command="{Binding DeleteCommand}"     Style="{StaticResource TransportButton}"/>
                <Border Width="1" Background="{StaticResource PanelBorderBrush}" Margin="12,2"/>
                <Button Content="⭱ Importar" Command="{Binding ImportCommand}"    Style="{StaticResource TransportButton}"/>
                <Button Content="⭳ Exportar" Command="{Binding ExportCommand}"    Style="{StaticResource TransportButton}"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#0C0F15" Padding="12,6">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
        </Border>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <!-- Panel izquierdo: formatos / categorías -->
            <DockPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock DockPanel.Dock="Top" Text="FORMATOS" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="2,0,0,6"/>
                <ListBox Style="{StaticResource DarkList}" ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory}" DisplayMemberPath="Label"/>
            </DockPanel>

            <!-- Panel central: presets -->
            <DockPanel Grid.Column="1" Margin="0,0,10,0">
                <TextBlock DockPanel.Dock="Top" Text="PRESETS" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="2,0,0,6"/>
                <ListBox Style="{StaticResource DarkList}" ItemsSource="{Binding Presets}"
                         SelectedItem="{Binding SelectedPreset}" HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Width="26" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}">
                                    <TextBlock Text="★" FontSize="14">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#3A4150"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource SignalAmberBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="10" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <Border Grid.Column="2" VerticalAlignment="Center" CornerRadius="3" Padding="5,1" Margin="6,0,2,0"
                                        Background="#232936"
                                        Visibility="{Binding IsBuiltIn, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="fábrica" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Panel derecho: detalle + comando + aplicar -->
            <Border Grid.Column="2" Background="{StaticResource PanelBrush}" CornerRadius="8"
                    BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" Padding="16">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="{Binding SelectedPreset.Name}" FontSize="17" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding SelectedPreset.Description}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,12"/>
                        <TextBlock Text="{Binding Detail}" FontFamily="Consolas" FontSize="12"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <!-- Aplicar a canal -->
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,12,0,0">
                        <TextBlock Text="Aplicar a:" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                        <ComboBox Width="90" Height="28" ItemsSource="{Binding Channels}" SelectedItem="{Binding TargetChannel}" DisplayMemberPath="Key"/>
                        <Button Content="Aplicar al canal" Command="{Binding ApplyCommand}" Style="{StaticResource StartButton}" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- Línea de comandos FFmpeg -->
                    <DockPanel Margin="0,14,0,0">
                        <TextBlock DockPanel.Dock="Top" Text="Línea de comandos FFmpeg" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding CommandLine, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap"
                                 FontFamily="Consolas" FontSize="11" Background="{StaticResource PreviewBrush}"
                                 Foreground="#9FE8C0" BorderThickness="0" Padding="8"
                                 VerticalScrollBarVisibility="Auto"/>
                    </DockPanel>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
