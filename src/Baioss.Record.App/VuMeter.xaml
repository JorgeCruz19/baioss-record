<UserControl x:Class="Baioss.Record.App.VuMeter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Barra VU/Peak: gradiente fijo (verde→ámbar→rojo) revelado por un clip según
         el nivel, más una línea blanca de peak-hold. El color por posición es absoluto. -->
    <Grid x:Name="Root" Width="14" SizeChanged="OnSizeChanged">
        <Border Background="#0E1117" CornerRadius="2"/>
        <Rectangle x:Name="Fill" SnapsToDevicePixels="True">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                    <GradientStop Color="#26A269" Offset="0.0"/>
                    <GradientStop Color="#26A269" Offset="0.6"/>
                    <GradientStop Color="#F5A623" Offset="0.82"/>
                    <GradientStop Color="#E5484D" Offset="1.0"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
            <Rectangle.Clip>
                <RectangleGeometry x:Name="FillClip"/>
            </Rectangle.Clip>
        </Rectangle>
        <Line x:Name="PeakLine" Stroke="#FFFFFF" StrokeThickness="2"/>
    </Grid>
</UserControl>
