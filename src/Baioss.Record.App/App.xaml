<Application x:Class="Baioss.Record.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Tema oscuro broadcast -->
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <SolidColorBrush x:Key="PanelBrush"          Color="#161A22"/>
            <SolidColorBrush x:Key="PreviewBrush"        Color="#0A0C10"/>
            <SolidColorBrush x:Key="PanelBorderBrush"    Color="#2A2F3A"/>
            <SolidColorBrush x:Key="TextPrimaryBrush"    Color="#E6E9EF"/>
            <SolidColorBrush x:Key="TextSecondaryBrush"  Color="#8A92A0"/>
            <SolidColorBrush x:Key="AccentBrush"         Color="#3B82F6"/>
            <SolidColorBrush x:Key="RecBrush"            Color="#E5484D"/>
            <SolidColorBrush x:Key="SignalGreenBrush"    Color="#30A46C"/>
            <SolidColorBrush x:Key="SignalAmberBrush"    Color="#F5A623"/>
            <SolidColorBrush x:Key="SignalGrayBrush"     Color="#5A6472"/>
            <SolidColorBrush x:Key="ButtonBrush"         Color="#232936"/>

            <!-- Texto claro por defecto -->
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
            </Style>

            <!-- Botón de transporte base -->
            <Style x:Key="TransportButton" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="Background" Value="{StaticResource ButtonBrush}"/>
                <Setter Property="Padding" Value="14,9"/>
                <Setter Property="Margin" Value="0,0,8,0"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.35"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="StartButton" TargetType="Button" BasedOn="{StaticResource TransportButton}">
                <Setter Property="Background" Value="{StaticResource SignalGreenBrush}"/>
            </Style>
            <Style x:Key="StopButton" TargetType="Button" BasedOn="{StaticResource TransportButton}">
                <Setter Property="Background" Value="{StaticResource RecBrush}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
